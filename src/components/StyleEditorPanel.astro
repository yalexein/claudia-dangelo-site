            <div class="style-editor-field">
              <label for={`editor-content-y-${storageNamespace}`}>Posizione Y</label>
              <input id={`editor-content-y-${storageNamespace}`} type="range" data-content-y />
              <span class="style-editor-range-value" data-content-value="y">0px</span>
