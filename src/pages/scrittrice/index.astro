---
import WriterLayout from "../../layouts/WriterLayout.astro";
---
<WriterLayout title="Scrittrice">
  <h1>Scrittrice</h1>
  <p>
    Questa sezione avrà un tema e una tipografia dedicati. Qui metteremo bio, opere, testi e una pagina contatti.
  </p>

  <section class="grid">
    <a class="tile" href="#">
      <h2>Bio</h2>
      <p>Una bio breve + una lunga.</p>
    </a>
    <a class="tile" href="#">
      <h2>Opere</h2>
      <p>Libri, racconti, pubblicazioni.</p>
    </a>
    <a class="tile" href="#">
      <h2>Contatti</h2>
      <p>Email e social (se vuoi).</p>
    </a>
  </section>
</WriterLayout>

