---
import "../styles/editor-panel.css";

type SelectOption = {
  label: string;
  value: string;
};

type PageControl = {
  key: string;
  type: "range" | "color" | "select" | "toggle";
  label: string;
  default: string | number | boolean;
  cssVar?: string;
  min?: number;
  max?: number;
  step?: number;
  unit?: string;
  options?: SelectOption[];
  storageKey?: string;
  wide?: boolean;
};

type ContentBounds = {
  minX?: number;
  maxX?: number;
  minY?: number;
  maxY?: number;
  minRotate?: number;
  maxRotate?: number;
};

type ContentBlockStyle = {
  fontFamily?: string;
  fontSize?: number;
  lineHeight?: number;
  letterSpacing?: number;
  wordSpacing?: number;
  textAlign?: "left" | "center" | "right" | "justify";
  fontWeight?: string;
  fontStyle?: string;
  color?: string;
};

type ContentBlockDefinition = {
  id: string;
  label?: string;
  selector: string;
  defaultText: string;
  editable?: boolean;
  transform?: "none" | "xy" | "xy-rotate";
  desktopOnlyTransform?: boolean;
  bounds?: ContentBounds;
  styleEditable?: boolean;
  defaultStyle?: Partial<ContentBlockStyle>;
};

const fontOptions = [
  {
    label: "Baskerville",
    value:
      '"Baskerville", "Iowan Old Style", "Palatino Linotype", "Book Antiqua", Garamond, Georgia, serif',
  },
  {
    label: "Didot",
    value: '"Didot", "Bodoni 72", "Bodoni MT", "Times New Roman", serif',
  },
  {
    label: "Garamond",
    value: '"Cormorant Garamond", "Adobe Garamond Pro", Garamond, Georgia, serif',
  },
  {
    label: "Caslon",
    value: '"Big Caslon", "Book Antiqua", "Palatino Linotype", serif',
  },
  {
    label: "Hoefler Text",
    value: '"Hoefler Text", "Iowan Old Style", Georgia, serif',
  },
  {
    label: "Times New Roman",
    value: '"Times New Roman", Times, serif',
  },
  {
    label: "Georgia",
    value: 'Georgia, "Times New Roman", serif',
  },
  {
    label: "Cormorant",
    value: '"Cormorant Infant", "Cormorant Garamond", Georgia, serif',
  },
  {
    label: "IBM Plex Mono",
    value: '"IBM Plex Mono", "Courier New", monospace',
  },
  {
    label: "PT Mono Local",
    value: '"PT Mono Local", "IBM Plex Mono", "Courier New", monospace',
  },
  {
    label: "Space Mono",
    value: '"Space Mono", "Courier New", monospace',
  },
  {
    label: "Comic Neue",
    value: '"Comic Neue", "Comic Sans MS", cursive',
  },
  {
    label: "Bradley Hand Local",
    value: '"Bradley Hand Local", "Comic Neue", "Comic Sans MS", cursive',
  },
  {
    label: "Patrick Hand",
    value: '"Patrick Hand", "Comic Sans MS", cursive',
  },
];

const defaultPresets = {
  background: "#fffdfb",
  background2: "#f5efe8",
  background3: "#ffe4e8",
  backgroundMode: "solid",
  backgroundAngle: 90,
  text: "#1f1a17",
  text2: "#6d4a42",
  text3: "#ef4b5b",
  textMode: "solid",
  textAngle: 90,
  accent: "#ef4b5b",
  font:
    '"Baskerville", "Iowan Old Style", "Palatino Linotype", "Book Antiqua", Garamond, Georgia, serif',
  titleFont: '"Didot", "Bodoni 72", "Bodoni MT", "Times New Roman", serif',
  fontSize: 23,
  lineHeight: 1.47,
  letterSpacing: -0.012,
  wordSpacing: 0,
  copyWidth: 72,
  align: "left",
  x: 0,
  y: 0,
};

const {
  panelTitle = "Style editor",
  storageNamespace = "bio",
  presets = {},
  pageControls = [],
  pageDefaults = {},
  pageSectionTitle = "Impostazioni pagina",
  contentSchema = [],
  contentStorageNamespace = storageNamespace,
  contentSectionTitle = "Contenuti",
} = Astro.props as {
  panelTitle?: string;
  storageNamespace?: string;
  presets?: Record<string, string | number>;
  pageControls?: PageControl[];
  pageDefaults?: Record<string, string | number | boolean>;
  pageSectionTitle?: string;
  contentSchema?: ContentBlockDefinition[];
  contentStorageNamespace?: string;
  contentSectionTitle?: string;
};

const mergedPresets = { ...defaultPresets, ...presets };

const normalizedPageControls = pageControls.map((control) => {
  const fallbackDefault = pageDefaults[control.key] ?? control.default;
  return { ...control, default: fallbackDefault };
});

const pageDefaultMap = Object.fromEntries(
  normalizedPageControls.map((control) => [control.key, control.default]),
);

const mergedDefaults = { ...mergedPresets, ...pageDefaultMap };

const pageControlMeta = normalizedPageControls.map((control) => ({
  key: control.key,
  type: control.type,
  unit: control.unit ?? "",
  cssVar: control.cssVar ?? "",
  storageKey: control.storageKey ?? "",
  fallback: control.default,
}));

const normalizeContentStyle = (rawStyle?: Partial<ContentBlockStyle>) => {
  if (!rawStyle || typeof rawStyle !== "object") return {};
  const normalized: Partial<ContentBlockStyle> = {};

  if (typeof rawStyle.fontFamily === "string" && rawStyle.fontFamily.trim()) normalized.fontFamily = rawStyle.fontFamily;
  if (typeof rawStyle.fontSize === "number" && Number.isFinite(rawStyle.fontSize)) normalized.fontSize = rawStyle.fontSize;
  if (typeof rawStyle.lineHeight === "number" && Number.isFinite(rawStyle.lineHeight)) normalized.lineHeight = rawStyle.lineHeight;
  if (typeof rawStyle.letterSpacing === "number" && Number.isFinite(rawStyle.letterSpacing))
    normalized.letterSpacing = rawStyle.letterSpacing;
  if (typeof rawStyle.wordSpacing === "number" && Number.isFinite(rawStyle.wordSpacing)) normalized.wordSpacing = rawStyle.wordSpacing;
  if (typeof rawStyle.textAlign === "string" && rawStyle.textAlign.trim()) normalized.textAlign = rawStyle.textAlign as ContentBlockStyle["textAlign"];
  if (typeof rawStyle.fontWeight === "string" && rawStyle.fontWeight.trim()) normalized.fontWeight = rawStyle.fontWeight;
  if (typeof rawStyle.fontStyle === "string" && rawStyle.fontStyle.trim()) normalized.fontStyle = rawStyle.fontStyle;
  if (typeof rawStyle.color === "string" && rawStyle.color.trim()) normalized.color = rawStyle.color;

  return normalized;
};

const normalizedContentSchema = contentSchema.map((block) => ({
  id: block.id,
  label: block.label ?? block.id,
  selector: block.selector,
  defaultText: block.defaultText,
  editable: block.editable !== false,
  transform: block.transform ?? "none",
  desktopOnlyTransform: Boolean(block.desktopOnlyTransform),
  bounds: block.bounds ?? {},
  styleEditable: block.styleEditable !== false,
  defaultStyle: normalizeContentStyle(block.defaultStyle),
}));

const toBoolean = (value: unknown) =>
  value === true || value === 1 || value === "1" || value === "true" || value === "on";

const formatControlValue = (control: PageControl) => {
  if (control.type === "toggle") {
    return toBoolean(control.default) ? "On" : "Off";
  }

  if (control.unit) {
    return `${control.default}${control.unit}`;
  }

  return `${control.default}`;
};

const storageKey = `claudia-editor-${storageNamespace}-settings`;
const panelStateKey = `claudia-editor-${storageNamespace}-panel-open`;
const contentNamespace = contentStorageNamespace || storageNamespace;
const contentStorageKey = `claudia-content-${contentNamespace}-v1`;
---

<aside
  class="style-editor-panel"
  data-style-editor
  data-storage-key={storageKey}
  data-panel-key={panelStateKey}
  data-content-storage-key={contentStorageKey}
  data-content-namespace={contentNamespace}
>
  <div class="style-editor-panel__topbar">
    <h2>{panelTitle}</h2>
    <button class="style-editor-collapse" type="button" data-style-collapse aria-expanded="true">
      Nascondi
    </button>
  </div>

  <div class="style-editor-panel__content">
    <div class="style-editor-grid">
      <div class="style-editor-field">
        <label for={`editor-bg-mode-${storageNamespace}`}>Sfondo</label>
        <select id={`editor-bg-mode-${storageNamespace}`} data-style-control="backgroundMode">
          <option value="solid" selected={mergedPresets.backgroundMode === "solid"}>Solido</option>
          <option value="linear-2" selected={mergedPresets.backgroundMode === "linear-2"}>Lineare 2</option>
          <option value="linear-3" selected={mergedPresets.backgroundMode === "linear-3"}>Lineare 3</option>
          <option value="radial-2" selected={mergedPresets.backgroundMode === "radial-2"}>Radiale 2</option>
          <option value="radial-3" selected={mergedPresets.backgroundMode === "radial-3"}>Radiale 3</option>
        </select>
      </div>

      <div class="style-editor-field">
        <label for={`editor-text-mode-${storageNamespace}`}>Testo</label>
        <select id={`editor-text-mode-${storageNamespace}`} data-style-control="textMode">
          <option value="solid" selected={mergedPresets.textMode === "solid"}>Solido</option>
          <option value="linear-2" selected={mergedPresets.textMode === "linear-2"}>Lineare 2</option>
          <option value="linear-3" selected={mergedPresets.textMode === "linear-3"}>Lineare 3</option>
          <option value="radial-2" selected={mergedPresets.textMode === "radial-2"}>Radiale 2</option>
          <option value="radial-3" selected={mergedPresets.textMode === "radial-3"}>Radiale 3</option>
        </select>
      </div>

      <div class="style-editor-field">
        <label for={`editor-bg-1-${storageNamespace}`}>Sfondo 1</label>
        <input
          id={`editor-bg-1-${storageNamespace}`}
          type="color"
          value={mergedPresets.background}
          data-style-control="background"
        />
      </div>

      <div class="style-editor-field">
        <label for={`editor-text-1-${storageNamespace}`}>Testo 1</label>
        <input
          id={`editor-text-1-${storageNamespace}`}
          type="color"
          value={mergedPresets.text}
          data-style-control="text"
        />
      </div>

      <div class="style-editor-field">
        <label for={`editor-bg-2-${storageNamespace}`}>Sfondo 2</label>
        <input
          id={`editor-bg-2-${storageNamespace}`}
          type="color"
          value={mergedPresets.background2}
          data-style-control="background2"
        />
      </div>

      <div class="style-editor-field">
        <label for={`editor-text-2-${storageNamespace}`}>Testo 2</label>
        <input id={`editor-text-2-${storageNamespace}`} type="color" value={mergedPresets.text2} data-style-control="text2" />
      </div>

      <div class="style-editor-field">
        <label for={`editor-bg-3-${storageNamespace}`}>Sfondo 3</label>
        <input
          id={`editor-bg-3-${storageNamespace}`}
          type="color"
          value={mergedPresets.background3}
          data-style-control="background3"
        />
      </div>

      <div class="style-editor-field">
        <label for={`editor-text-3-${storageNamespace}`}>Testo 3</label>
        <input id={`editor-text-3-${storageNamespace}`} type="color" value={mergedPresets.text3} data-style-control="text3" />
      </div>

      <div class="style-editor-field">
        <label for={`editor-accent-${storageNamespace}`}>Accento</label>
        <input id={`editor-accent-${storageNamespace}`} type="color" value={mergedPresets.accent} data-style-control="accent" />
      </div>

      <div class="style-editor-field">
        <label for={`editor-align-${storageNamespace}`}>Allineamento</label>
        <select id={`editor-align-${storageNamespace}`} data-style-control="align">
          <option value="left" selected={mergedPresets.align === "left"}>Sinistra</option>
          <option value="center" selected={mergedPresets.align === "center"}>Centro</option>
          <option value="right" selected={mergedPresets.align === "right"}>Destra</option>
          <option value="justify" selected={mergedPresets.align === "justify"}>Giustificato</option>
        </select>
      </div>

      <div class="style-editor-field">
        <label for={`editor-bg-angle-${storageNamespace}`}>Angolo sfondo</label>
        <input
          id={`editor-bg-angle-${storageNamespace}`}
          type="range"
          min="0"
          max="360"
          step="1"
          value={mergedPresets.backgroundAngle}
          data-style-control="backgroundAngle"
        />
        <span class="style-editor-range-value" data-style-value="backgroundAngle">{mergedPresets.backgroundAngle}°</span>
      </div>

      <div class="style-editor-field">
        <label for={`editor-text-angle-${storageNamespace}`}>Angolo testo</label>
        <input
          id={`editor-text-angle-${storageNamespace}`}
          type="range"
          min="0"
          max="360"
          step="1"
          value={mergedPresets.textAngle}
          data-style-control="textAngle"
        />
        <span class="style-editor-range-value" data-style-value="textAngle">{mergedPresets.textAngle}°</span>
      </div>

      <div class="style-editor-field style-editor-field--wide">
        <label for={`editor-font-${storageNamespace}`}>Font</label>
        <select id={`editor-font-${storageNamespace}`} data-style-control="font">
          {fontOptions.map((option) => (
            <option value={option.value} selected={mergedPresets.font === option.value}>
              {option.label}
            </option>
          ))}
        </select>
      </div>

      <div class="style-editor-field style-editor-field--wide">
        <label for={`editor-title-font-${storageNamespace}`}>Font titolo</label>
        <select id={`editor-title-font-${storageNamespace}`} data-style-control="titleFont">
          {fontOptions.map((option) => (
            <option value={option.value} selected={mergedPresets.titleFont === option.value}>
              {option.label}
            </option>
          ))}
        </select>
      </div>

      <div class="style-editor-field">
        <label for={`editor-font-size-${storageNamespace}`}>Font size</label>
        <input
          id={`editor-font-size-${storageNamespace}`}
          type="range"
          min="12"
          max="64"
          step="1"
          value={mergedPresets.fontSize}
          data-style-control="fontSize"
        />
        <span class="style-editor-range-value" data-style-value="fontSize">{mergedPresets.fontSize}px</span>
      </div>

      <div class="style-editor-field">
        <label for={`editor-line-height-${storageNamespace}`}>Interlinea</label>
        <input
          id={`editor-line-height-${storageNamespace}`}
          type="range"
          min="0.8"
          max="3"
          step="0.01"
          value={mergedPresets.lineHeight}
          data-style-control="lineHeight"
        />
        <span class="style-editor-range-value" data-style-value="lineHeight">{mergedPresets.lineHeight}</span>
      </div>

      <div class="style-editor-field">
        <label for={`editor-letter-spacing-${storageNamespace}`}>Tracking</label>
        <input
          id={`editor-letter-spacing-${storageNamespace}`}
          type="range"
          min="-0.08"
          max="0.18"
          step="0.001"
          value={mergedPresets.letterSpacing}
          data-style-control="letterSpacing"
        />
        <span class="style-editor-range-value" data-style-value="letterSpacing">{mergedPresets.letterSpacing}em</span>
      </div>

      <div class="style-editor-field">
        <label for={`editor-word-spacing-${storageNamespace}`}>Spazio parole</label>
        <input
          id={`editor-word-spacing-${storageNamespace}`}
          type="range"
          min="-0.2"
          max="0.8"
          step="0.005"
          value={mergedPresets.wordSpacing}
          data-style-control="wordSpacing"
        />
        <span class="style-editor-range-value" data-style-value="wordSpacing">{mergedPresets.wordSpacing}em</span>
      </div>

      <div class="style-editor-field">
        <label for={`editor-copy-width-${storageNamespace}`}>Larghezza testo</label>
        <input
          id={`editor-copy-width-${storageNamespace}`}
          type="range"
          min="20"
          max="190"
          step="1"
          value={mergedPresets.copyWidth}
          data-style-control="copyWidth"
        />
        <span class="style-editor-range-value" data-style-value="copyWidth">{mergedPresets.copyWidth}ch</span>
      </div>

      <div class="style-editor-field">
        <label for={`editor-x-${storageNamespace}`}>Posizione X</label>
        <input id={`editor-x-${storageNamespace}`} type="range" min="-700" max="700" step="2" value={mergedPresets.x} data-style-control="x" />
        <span class="style-editor-range-value" data-style-value="x">{mergedPresets.x}px</span>
      </div>

      <div class="style-editor-field">
        <label for={`editor-y-${storageNamespace}`}>Posizione Y</label>
        <input id={`editor-y-${storageNamespace}`} type="range" min="-320" max="320" step="2" value={mergedPresets.y} data-style-control="y" />
        <span class="style-editor-range-value" data-style-value="y">{mergedPresets.y}px</span>
      </div>

      {normalizedPageControls.length > 0 && (
        <>
          <div class="style-editor-divider" aria-hidden="true"></div>
          <h3 class="style-editor-subtitle">{pageSectionTitle}</h3>

          {normalizedPageControls.map((control) => (
            <div class:list={["style-editor-field", control.wide && "style-editor-field--wide"]}>
              <label for={`editor-page-${control.key}-${storageNamespace}`}>{control.label}</label>

              {control.type === "color" && (
                <input
                  id={`editor-page-${control.key}-${storageNamespace}`}
                  type="color"
                  value={String(control.default)}
                  data-style-control={control.key}
                  data-style-type={control.type}
                  data-style-css-var={control.cssVar ?? ""}
                  data-style-unit={control.unit ?? ""}
                  data-style-storage-key={control.storageKey ?? ""}
                />
              )}

              {control.type === "range" && (
                <>
                  <input
                    id={`editor-page-${control.key}-${storageNamespace}`}
                    type="range"
                    min={control.min}
                    max={control.max}
                    step={control.step}
                    value={String(control.default)}
                    data-style-control={control.key}
                    data-style-type={control.type}
                    data-style-css-var={control.cssVar ?? ""}
                    data-style-unit={control.unit ?? ""}
                    data-style-storage-key={control.storageKey ?? ""}
                  />
                  <span class="style-editor-range-value" data-style-value={control.key}>
                    {formatControlValue(control)}
                  </span>
                </>
              )}

              {control.type === "select" && (
                <select
                  id={`editor-page-${control.key}-${storageNamespace}`}
                  data-style-control={control.key}
                  data-style-type={control.type}
                  data-style-css-var={control.cssVar ?? ""}
                  data-style-unit={control.unit ?? ""}
                  data-style-storage-key={control.storageKey ?? ""}
                >
                  {(control.options ?? []).map((option) => (
                    <option value={option.value} selected={String(control.default) === option.value}>{option.label}</option>
                  ))}
                </select>
              )}

              {control.type === "toggle" && (
                <>
                  <label class="style-editor-toggle" for={`editor-page-${control.key}-${storageNamespace}`}>
                    <input
                      id={`editor-page-${control.key}-${storageNamespace}`}
                      type="checkbox"
                      checked={toBoolean(control.default)}
                      data-style-control={control.key}
                      data-style-type={control.type}
                      data-style-css-var={control.cssVar ?? ""}
                      data-style-unit={control.unit ?? ""}
                      data-style-storage-key={control.storageKey ?? ""}
                    />
                    <span>Attiva</span>
                  </label>
                  <span class="style-editor-range-value" data-style-value={control.key}>
                    {formatControlValue(control)}
                  </span>
                </>
              )}
            </div>
          ))}
        </>
      )}
    </div>

    <div class="style-editor-actions">
      <button class="style-editor-save" type="button" data-style-save>Salva</button>
      <button class="style-editor-reset" type="button" data-style-reset>Reset</button>
    </div>
    <p class="style-editor-status" data-style-status aria-live="polite"></p>

    {normalizedContentSchema.length > 0 && (
      <div class="style-editor-content">
        <div class="style-editor-divider" aria-hidden="true"></div>
        <h3 class="style-editor-subtitle">{contentSectionTitle}</h3>

        <div class="style-editor-grid">
          <div class="style-editor-field style-editor-field--wide">
            <label class="style-editor-toggle" for={`editor-content-mode-${storageNamespace}`}>
              <input id={`editor-content-mode-${storageNamespace}`} type="checkbox" data-content-edit-mode />
              <span>Edit mode</span>
            </label>
          </div>

          <div class="style-editor-field style-editor-field--wide">
            <label for={`editor-content-block-${storageNamespace}`}>Blocco testo</label>
            <select id={`editor-content-block-${storageNamespace}`} data-content-block-select>
              {normalizedContentSchema.map((block) => (
                <option value={block.id}>{block.label}</option>
              ))}
            </select>
            <p class="style-editor-context-note" data-content-active-label>Stai modificando: —</p>
          </div>

          <div class="style-editor-field style-editor-field--wide">
            <label for={`editor-content-text-${storageNamespace}`}>Testo</label>
            <textarea id={`editor-content-text-${storageNamespace}`} rows={6} data-content-text></textarea>
          </div>

          <details class="style-editor-advanced style-editor-field--wide" data-content-style-advanced>
            <summary>Tipografia box (Advanced)</summary>
            <p class="style-editor-context-note style-editor-context-note--compact" data-content-style-scope>
              Le impostazioni qui sotto si applicano solo al box selezionato.
            </p>
            <div class="style-editor-grid style-editor-grid--content-style">
              <div class="style-editor-field style-editor-field--wide">
                <label for={`editor-content-style-font-${storageNamespace}`}>Font box</label>
                <select id={`editor-content-style-font-${storageNamespace}`} data-content-style-font>
                  {fontOptions.map((option) => (
                    <option value={option.value}>{option.label}</option>
                  ))}
                </select>
              </div>

              <div class="style-editor-field">
                <label for={`editor-content-style-size-${storageNamespace}`}>Font size</label>
                <input
                  id={`editor-content-style-size-${storageNamespace}`}
                  type="range"
                  min="10"
                  max="96"
                  step="0.1"
                  data-content-style-size
                />
                <span class="style-editor-range-value" data-content-style-value="fontSize">0px</span>
              </div>

              <div class="style-editor-field">
                <label for={`editor-content-style-line-height-${storageNamespace}`}>Interlinea</label>
                <input
                  id={`editor-content-style-line-height-${storageNamespace}`}
                  type="range"
                  min="0.8"
                  max="3"
                  step="0.01"
                  data-content-style-line-height
                />
                <span class="style-editor-range-value" data-content-style-value="lineHeight">0</span>
              </div>

              <div class="style-editor-field">
                <label for={`editor-content-style-letter-spacing-${storageNamespace}`}>Tracking</label>
                <input
                  id={`editor-content-style-letter-spacing-${storageNamespace}`}
                  type="range"
                  min="-0.1"
                  max="0.3"
                  step="0.001"
                  data-content-style-letter-spacing
                />
                <span class="style-editor-range-value" data-content-style-value="letterSpacing">0em</span>
              </div>

              <div class="style-editor-field">
                <label for={`editor-content-style-word-spacing-${storageNamespace}`}>Spazio parole</label>
                <input
                  id={`editor-content-style-word-spacing-${storageNamespace}`}
                  type="range"
                  min="-0.2"
                  max="1"
                  step="0.005"
                  data-content-style-word-spacing
                />
                <span class="style-editor-range-value" data-content-style-value="wordSpacing">0em</span>
              </div>

              <div class="style-editor-field">
                <label for={`editor-content-style-align-${storageNamespace}`}>Allineamento</label>
                <select id={`editor-content-style-align-${storageNamespace}`} data-content-style-align>
                  <option value="left">Sinistra</option>
                  <option value="center">Centro</option>
                  <option value="right">Destra</option>
                  <option value="justify">Giustificato</option>
                </select>
              </div>

              <div class="style-editor-field">
                <label for={`editor-content-style-color-${storageNamespace}`}>Colore testo</label>
