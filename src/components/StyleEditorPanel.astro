                  <span>Grassetto</span>
                </label>
              </div>

              <div class="style-editor-field">
                <label class="style-editor-toggle" for={`editor-content-style-italic-${storageNamespace}`}>
                  <input id={`editor-content-style-italic-${storageNamespace}`} type="checkbox" data-content-style-italic />
                  <span>Corsivo</span>
                </label>
