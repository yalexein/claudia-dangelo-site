---
import InteractiveSwapImage from "./InteractiveSwapImage.astro";
import WindowBird from "./WindowBird.astro";

const base = import.meta.env.BASE_URL;

const landingElements = [
  {
    id: "desk",
    alt: "Una scrivania classica in legno vista di fronte, con due colonne di cassetti laterali.",
    defaultSrc: `${base}images/landing/desk/desk-default-real.webp`,
    position: {
      left: "50%",
      bottom: "8%",
    },
    size: {
      width: "72%",
    },
    aspectRatio: "1536 / 1024",
    hotspots: [
      {
        id: "desk-left-top",
        left: "7.2%",
        top: "21%",
        width: "20.5%",
        height: "14.5%",
        clip: {
          left: "5.8%",
          top: "22.4%",
          width: "22.2%",
          height: "16.8%",
        },
        ariaLabel: "Cassetto in alto a sinistra della scrivania",
        hoverSrc: `${base}images/landing/desk/desk-left-top-open.webp`,
      },
      {
        id: "desk-left-middle",
        left: "7.2%",
        top: "38.3%",
        width: "20.5%",
        height: "15.5%",
        clip: {
          left: "6%",
          top: "31.8%",
          width: "22.2%",
          height: "18.6%",
        },
        ariaLabel: "Cassetto centrale a sinistra della scrivania",
        hoverSrc: `${base}images/landing/desk/desk-left-middle-open.webp`,
      },
      {
        id: "desk-left-bottom",
        left: "7.2%",
        top: "56.8%",
        width: "20.5%",
        height: "20.5%",
        clip: {
          left: "5.6%",
          top: "54.2%",
          width: "23.2%",
          height: "25.8%",
        },
        ariaLabel: "Cassetto in basso a sinistra della scrivania",
        hoverSrc: `${base}images/landing/desk/desk-left-bottom-open.webp`,
      },
      {
        id: "desk-right-top",
        left: "72.2%",
        top: "21%",
        width: "20.5%",
        height: "14.5%",
        clip: {
          left: "71.4%",
          top: "22.1%",
          width: "23.2%",
          height: "16.8%",
        },
        ariaLabel: "Cassetto in alto a destra della scrivania",
        hoverSrc: `${base}images/landing/desk/desk-right-top-open.webp`,
      },
      {
        id: "desk-right-middle",
        left: "72.2%",
        top: "38.3%",
        width: "20.5%",
        height: "15.5%",
        clip: {
          left: "71.2%",
          top: "30.6%",
          width: "25.1%",
          height: "24.5%",
        },
        ariaLabel: "Cassetto centrale a destra della scrivania",
        hoverSrc: `${base}images/landing/desk/desk-right-middle-open.webp`,
      },
      {
        id: "desk-right-bottom",
        left: "72.2%",
        top: "56.8%",
        width: "20.5%",
        height: "20.5%",
        clip: {
          left: "69.6%",
          top: "49.7%",
          width: "30.4%",
          height: "37.5%",
        },
        ariaLabel: "Cassetto in basso a destra della scrivania",
        hoverSrc: `${base}images/landing/desk/desk-right-bottom-open.webp`,
      },
    ],
  },
];
---

<section class="landing-stage" aria-labelledby="landing-title">
  <div class="site-signature">
    <p class="site-name" id="landing-title">Claudia D'Angelo</p>
    <p class="site-whisper">una stanza composta da oggetti indipendenti</p>
  </div>

  <div class="landing-scene" aria-label="Landing costruita con elementi illustrati indipendenti">
    {landingElements.map((element) => <InteractiveSwapImage element={element} />)}
    <WindowBird />
  </div>
</section>
