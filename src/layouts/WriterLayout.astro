---
import "../styles/writer.css";

const { title = "Scrittrice" } = Astro.props;
const base = import.meta.env.BASE_URL;
---
<!doctype html>
<html lang="it">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href={`${base}favicon.svg`} />
  </head>
  <body>
    <header class="topbar">
      <a class="brand" href={base}>Home</a>
      <nav class="nav">
        <a aria-current="page" href={`${base}scrittrice/`}>Scrittrice</a>
        <a href={`${base}collagista/`}>Collagista</a>
      </nav>
    </header>
    <main class="container">
      <slot />
    </main>
  </body>
</html>
