            <div class="style-editor-field">
              <label for={`editor-content-rotate-${storageNamespace}`}>Rotazione</label>
              <input id={`editor-content-rotate-${storageNamespace}`} type="range" data-content-rotate />
              <span class="style-editor-range-value" data-content-value="rotate">0°</span>
